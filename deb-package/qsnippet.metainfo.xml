<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.qsnippet.QSnippet</id>
  <name>QSnippet</name>
  <summary>Lightweight snippet manager for quick text insertion</summary>
  <description>
    <p>
      QSnippet is a lightweight snippet manager that allows you to save and
      quickly insert text snippets across your applications. Perfect for developers,
      writers, and anyone who frequently uses the same text blocks.
    </p>
    <p>
      Features include:
    </p>
    <ul>
      <li>Create and organize code snippets</li>
      <li>Quick snippet insertion via hotkeys</li>
      <li>Support for placeholders and dynamic content</li>
      <li>Cross-platform compatibility (Windows, macOS, Linux)</li>
      <li>System tray integration</li>
    </ul>
  </description>

